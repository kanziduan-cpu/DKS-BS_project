<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/warehouseCard"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="8dp"
    android:layout_marginBottom="8dp"
    app:cardElevation="2dp"
    app:cardCornerRadius="12dp"
    app:cardBackgroundColor="@color/white"
    app:strokeColor="@color/card_border"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <!-- 仓库图标 -->
        <ImageView
            android:id="@+id/warehouseIcon"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:src="@drawable/ic_warehouse"
            android:background="@drawable/badge_background"
            android:padding="16dp"
            app:tint="@color/primary"
            android:contentDescription="仓库图标" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="12dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/warehouseName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="1 号仓库"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/warehouseAddress"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="北京市朝阳区 xx 街道 xx 号"
                android:textSize="14sp"
                android:textColor="@color/text_secondary"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/warehouseAccessCode"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="访问码：****1234"
                android:textSize="12sp"
                android:textColor="@color/text_hint"
                android:maxLines="1"
                android:ellipsize="end" />

        </LinearLayout>

        <!-- 解绑按钮 -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/unbindButton"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="解绑"
            android:textSize="12sp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            app:cornerRadius="18dp"
            app:strokeColor="@color/error"
            app:strokeWidth="1dp"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
