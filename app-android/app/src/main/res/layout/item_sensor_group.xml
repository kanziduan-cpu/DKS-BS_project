<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/sensorGroupCard"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardElevation="0dp"
    app:cardCornerRadius="16dp"
    app:cardBackgroundColor="@color/mi_translucent_white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <!-- 标题 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="10dp">

            <ImageView
                android:id="@+id/sensorIcon"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_weather"
                app:tint="@color/mi_blue"/>

            <TextView
                android:id="@+id/sensorTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="温湿度"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:layout_marginStart="6dp"/>

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1"/>

            <TextView
                android:id="@+id/sensorStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="正常"
                android:textSize="11sp"
                android:textColor="@color/mi_green"
                android:textStyle="bold"
                android:paddingHorizontal="10dp"
                android:paddingVertical="3dp"
                android:background="@drawable/mi_status_badge"/>
        </LinearLayout>

        <!-- 传感器数据网格 -->
        <LinearLayout
            android:id="@+id/sensorGrid"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">
            
            <!-- 动态添加传感器项 -->
        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
