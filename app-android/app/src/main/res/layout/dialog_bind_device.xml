<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@color/white">

    <!-- 标题 -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="绑定新设备"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="@color/text_title"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="请填写设备信息以完成绑定"
        android:textSize="14sp"
        android:textColor="@color/text_secondary"
        android:layout_marginBottom="24dp"/>

    <!-- 设备名称输入框 -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/deviceNameLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="设备名称"
        app:boxBackgroundMode="outline"
        app:boxCornerRadiusTopStart="12dp"
        app:boxCornerRadiusTopEnd="12dp"
        app:boxCornerRadiusBottomStart="12dp"
        app:boxCornerRadiusBottomEnd="12dp"
        app:boxStrokeColor="@color/mi_blue"
        app:hintTextColor="@color/mi_blue"
        android:layout_marginBottom="16dp">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/deviceNameInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="text"
            android:textSize="16sp"
            android:textColor="@color/text_primary"
            android:maxLength="20"/>

    </com.google.android.material.textfield.TextInputLayout>

    <!-- 设备地址输入框 -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/deviceAddressLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="设备地址"
        app:boxBackgroundMode="outline"
        app:boxCornerRadiusTopStart="12dp"
        app:boxCornerRadiusTopEnd="12dp"
        app:boxCornerRadiusBottomStart="12dp"
        app:boxCornerRadiusBottomEnd="12dp"
        app:boxStrokeColor="@color/mi_blue"
        app:hintTextColor="@color/mi_blue"
        app:helperText="示例：192.168.1.100 或 10.0.0.1"
        app:helperTextTextColor="@color/text_hint"
        android:layout_marginBottom="16dp">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/deviceAddressInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="textUri"
            android:textSize="16sp"
            android:textColor="@color/text_primary"
            android:maxLength="50"/>

    </com.google.android.material.textfield.TextInputLayout>

    <!-- 访问码输入框 -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/deviceAccessCodeLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="访问码"
        app:boxBackgroundMode="outline"
        app:boxCornerRadiusTopStart="12dp"
        app:boxCornerRadiusTopEnd="12dp"
        app:boxCornerRadiusBottomStart="12dp"
        app:boxCornerRadiusBottomEnd="12dp"
        app:boxStrokeColor="@color/mi_blue"
        app:hintTextColor="@color/mi_blue"
        app:helperText="示例：admin123 或 888888"
        app:helperTextTextColor="@color/text_hint"
        app:passwordToggleEnabled="true"
        app:passwordToggleTint="@color/text_hint"
        android:layout_marginBottom="24dp">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/deviceAccessCodeInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="textPassword"
            android:textSize="16sp"
            android:textColor="@color/text_primary"
            android:maxLength="32"/>

    </com.google.android.material.textfield.TextInputLayout>

    <!-- 按钮区域 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="end">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/cancelButton"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:text="取消"
            android:textSize="15sp"
            android:textColor="@color/text_primary"
            app:backgroundTint="@color/divider_light"
            app:cornerRadius="24dp"
            android:layout_marginEnd="12dp"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/confirmButton"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:text="确定"
            android:textSize="15sp"
            android:textColor="@color/white"
            app:backgroundTint="@color/mi_blue"
            app:cornerRadius="24dp"
            app:elevation="2dp"
            style="@style/Widget.MaterialComponents.Button"/>

    </LinearLayout>

</LinearLayout>
