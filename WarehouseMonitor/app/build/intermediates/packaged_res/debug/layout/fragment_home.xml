<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/mi_sky_gradient">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="80dp">

            <!-- Mi Home Style Header -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="48dp"
                android:paddingHorizontal="20dp"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                        <TextView
                            android:id="@+id/warehouseTitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="主仓库"
                            android:textSize="22sp"
                            android:textStyle="bold"
                            android:textColor="@color/white" />
                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@drawable/ic_arrow_right"
                            android:rotation="90"
                            app:tint="@color/white"
                            android:layout_marginStart="4dp"/>
                    </LinearLayout>

                    <!-- MQTT 连接状态指示器 -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="4dp">
                        <View
                            android:id="@+id/mqttStatusDot"
                            android:layout_width="8dp"
                            android:layout_height="8dp"
                            android:background="@drawable/mi_status_indicator"
                            android:backgroundTint="@color/offline" />
                        <TextView
                            android:id="@+id/mqttStatusText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="6dp"
                            android:text="正在连接服务器..."
                            android:textSize="12sp"
                            android:textColor="#CCFFFFFF" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:gravity="center_vertical">
                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_home"
                        app:tint="@color/white"
                        android:layout_marginEnd="4dp"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="12°"
                        android:textSize="18sp"
                        android:textColor="@color/white" />
                </LinearLayout>
            </RelativeLayout>

            <!-- Horizontal Tab Bar -->
            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none"
                android:layout_marginBottom="24dp">
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="20dp">
                    <TextView style="@style/MiTabItem" android:text="场景" android:alpha="1.0" android:textStyle="bold"/>
                    <TextView style="@style/MiTabItem" android:text="全库" />
                    <TextView style="@style/MiTabItem" android:text="东区" />
                    <TextView style="@style/MiTabItem" android:text="西区" />
                </LinearLayout>
            </HorizontalScrollView>

            <!-- Environment Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="环境 >"
                android:textSize="16sp"
                android:textColor="@color/white"
                android:layout_marginStart="20dp"
                android:layout_marginBottom="4dp"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="传感器阵列实时监测中"
                android:textSize="12sp"
                android:textColor="#CCFFFFFF"
                android:layout_marginStart="20dp"
                android:layout_marginBottom="12dp"/>

            <!-- Small Quick Env Cards -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/parameterRecyclerView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="16dp"
                android:clipToPadding="false"
                android:orientation="horizontal"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                android:layout_marginBottom="16dp"/>

            <!-- Large Chart Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/mi_translucent_white"
                app:strokeWidth="0dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="• 核心区域"
                            android:textSize="12sp"
                            android:textColor="@color/text_secondary"/>
                        <TextView
                            android:id="@+id/chartParamSpinner"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:text="温度 ▾"
                            android:textSize="12sp"
                            android:paddingHorizontal="8dp"
                            android:paddingVertical="4dp"
                            android:background="@drawable/badge_background"
                            android:textColor="@color/text_primary"/>
                    </RelativeLayout>
                    <com.github.mikephil.charting.charts.LineChart
                        android:id="@+id/lineChart"
                        android:layout_width="match_parent"
                        android:layout_height="150dp"
                        android:layout_marginTop="12dp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Grouped Sections -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="自动化控制 >"
                android:textSize="16sp"
                android:textColor="@color/white"
                android:layout_marginStart="20dp"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="12dp"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/quickDeviceRecyclerView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="12dp"
                android:clipToPadding="false"
                android:nestedScrollingEnabled="false" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</FrameLayout>
