<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="6dp"
    app:cardElevation="0dp"
    app:cardCornerRadius="16dp"
    app:cardBackgroundColor="@color/white"
    app:strokeWidth="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <!-- 状态指示器 -->
        <View
            android:id="@+id/statusIndicator"
            android:layout_width="4dp"
            android:layout_height="40dp"
            android:background="@color/alarm_red"/>

        <!-- 图标 -->
        <ImageView
            android:id="@+id/alarmIcon"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="12dp"
            android:src="@drawable/ic_alarms_filled"
            app:tint="@color/alarm_red"
            android:padding="8dp"/>

        <!-- 内容 -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/alarmTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="温度异常报警"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"/>

            <TextView
                android:id="@+id/alarmMessage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="核心区域温度超过阈值 35°C"
                android:textSize="13sp"
                android:textColor="@color/text_secondary"/>

            <TextView
                android:id="@+id/alarmTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="2024-03-04 14:30:25"
                android:textSize="11sp"
                android:textColor="@color/text_hint"/>

        </LinearLayout>

        <!-- 状态标签 -->
        <TextView
            android:id="@+id/alarmStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="未处理"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="@color/alarm_red"
            android:paddingHorizontal="8dp"
            android:paddingVertical="4dp"
            android:background="@drawable/mi_alarm_badge_red"/>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
