# 云端服务器环境变量配置
# 复制此文件为 .env 并根据实际情况修改

# ===== 服务器配置 =====
# API 服务端口
PORT=3000

# 运行环境（development/production）
NODE_ENV=production

# ===== 数据库配置 =====
# 如果使用 Supabase，填写以下配置
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here

# ===== MQTT 配置 =====
# MQTT Broker 地址（本地使用 localhost）
MQTT_HOST=localhost

# MQTT Broker 端口
MQTT_PORT=1884

# MQTT 用户名（如果启用了认证）
MQTT_USERNAME=

# MQTT 密码（如果启用了认证）
MQTT_PASSWORD=

# ===== 日志配置 =====
# 日志级别（error/warn/info/debug）
LOG_LEVEL=info

# 日志文件路径
LOG_PATH=./logs
